<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:FermataUI.ViewModels"
        xmlns:services="using:FermataUI.Services"
        x:Class="FermataUI.Views.HistoryWindow"
        x:DataType="vm:HistoryViewModel"
        Title="Fermata — History"
        Width="700"
        Height="520"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource FermataBgBrush}">

  <Grid RowDefinitions="Auto,*,Auto">

    <!-- Summary bar -->
    <Border Grid.Row="0"
            Background="{StaticResource FermataSurfaceBrush}"
            BorderBrush="{StaticResource FermataBorderBrush}"
            BorderThickness="0,0,0,1"
            Padding="24,12">
      <Grid ColumnDefinitions="*,*,*">

        <StackPanel Grid.Column="0" HorizontalAlignment="Center" Spacing="2">
          <TextBlock Text="{Binding WeekTotal}"
                     FontFamily="{StaticResource LoraFont}"
                     FontWeight="Bold" FontSize="22"
                     Foreground="{StaticResource FermataTextBrush}"
                     HorizontalAlignment="Center"/>
          <TextBlock Text="THIS WEEK"
                     FontFamily="{StaticResource LoraFont}"
                     FontSize="11"
                     Foreground="{StaticResource FermataMutedBrush}"
                     HorizontalAlignment="Center"/>
        </StackPanel>

        <StackPanel Grid.Column="1" HorizontalAlignment="Center" Spacing="2">
          <TextBlock Text="{Binding WeekContinued}"
                     FontFamily="{StaticResource LoraFont}"
                     FontWeight="Bold" FontSize="22"
                     Foreground="{StaticResource FermataAccentBrush}"
                     HorizontalAlignment="Center"/>
          <TextBlock Text="CONTINUED"
                     FontFamily="{StaticResource LoraFont}"
                     FontSize="11"
                     Foreground="{StaticResource FermataMutedBrush}"
                     HorizontalAlignment="Center"/>
        </StackPanel>

        <StackPanel Grid.Column="2" HorizontalAlignment="Center" Spacing="2">
          <TextBlock Text="{Binding WeekCancelled}"
                     FontFamily="{StaticResource LoraFont}"
                     FontWeight="Bold" FontSize="22"
                     Foreground="{StaticResource FermataTextBrush}"
                     HorizontalAlignment="Center"/>
          <TextBlock Text="CANCELLED"
                     FontFamily="{StaticResource LoraFont}"
                     FontSize="11"
                     Foreground="{StaticResource FermataMutedBrush}"
                     HorizontalAlignment="Center"/>
        </StackPanel>

      </Grid>
    </Border>

    <!-- Table -->
    <ScrollViewer Grid.Row="1">
      <DataGrid ItemsSource="{Binding Records}"
                IsReadOnly="True"
                CanUserReorderColumns="False"
                CanUserResizeColumns="True"
                Background="{StaticResource FermataBgBrush}"
                RowBackground="{StaticResource FermataBgBrush}"
                GridLinesVisibility="Horizontal"
                HorizontalGridLinesBrush="{StaticResource FermataBorderBrush}"
                FontFamily="{StaticResource LoraFont}"
                FontSize="13">

        <DataGrid.Columns>
          <DataGridTextColumn Header="Date / Time"
                              Binding="{Binding Timestamp}"
                              Width="160"/>
          <DataGridTextColumn Header="Application"
                              Binding="{Binding Application}"
                              Width="140"/>
          <DataGridTextColumn Header="Waited"
                              Binding="{Binding WaitedMs, StringFormat={}{0} ms}"
                              Width="90"/>
          <DataGridTemplateColumn Header="Outcome" Width="110">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate x:DataType="services:LaunchRecord">
                <Border HorizontalAlignment="Left" CornerRadius="3" Padding="6,2" Margin="4,0">
                  <Border.Styles>
                    <Style Selector="Border[Tag=continued]">
                      <Setter Property="Background" Value="#F0E6DC"/>
                    </Style>
                    <Style Selector="Border[Tag=cancelled]">
                      <Setter Property="Background" Value="#F5E8E8"/>
                    </Style>
                    <Style Selector="Border[Tag=timeout]">
                      <Setter Property="Background" Value="{StaticResource FermataSurfaceBrush}"/>
                    </Style>
                  </Border.Styles>
                  <TextBlock Text="{Binding Outcome}"
                             FontFamily="{StaticResource LoraFont}"
                             FontSize="11">
                    <TextBlock.Styles>
                      <Style Selector="TextBlock">
                        <Setter Property="Foreground" Value="{StaticResource FermataMutedBrush}"/>
                      </Style>
                    </TextBlock.Styles>
                  </TextBlock>
                </Border>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
          <DataGridTextColumn Header="Journal"
                              Binding="{Binding Journal}"
                              Width="*"/>
        </DataGrid.Columns>

        <DataGrid.Styles>
          <Style Selector="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource FermataSurfaceBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource FermataMutedBrush}"/>
            <Setter Property="FontFamily" Value="{StaticResource LoraFont}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="12,8"/>
          </Style>
          <Style Selector="DataGridRow:pointerover">
            <Setter Property="Background" Value="{StaticResource FermataSurfaceBrush}"/>
          </Style>
        </DataGrid.Styles>

      </DataGrid>
    </ScrollViewer>

    <!-- Load more -->
    <Button Grid.Row="2"
            Classes="FermataBtn"
            Content="Load more"
            HorizontalAlignment="Center"
            Margin="0,8"
            IsVisible="{Binding HasMore}"
            Command="{Binding LoadMoreCommand}"/>

  </Grid>

</Window>
